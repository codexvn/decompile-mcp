<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- ALL logging goes to stderr. stdout is reserved for MCP JSON-RPC protocol. -->
    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] [%X{traceId}] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Silence noisy libraries -->
    <logger name="org.apache.maven.resolver" level="WARN"/>
    <logger name="org.eclipse.aether" level="WARN"/>
    <logger name="org.benf.cfr" level="WARN"/>

    <root level="INFO">
        <appender-ref ref="STDERR"/>
    </root>
</configuration>
